# Copy to .env — never commit real keys (M0 exit criterion).
# Google Map Tiles API key -> photorealistic 3D tiles loaded directly from Google.
VITE_GOOGLE_TILES_KEY=
# Cesium ion token -> photorealistic 3D tiles via ion asset 2275207 (alternative to the Google key).
VITE_CESIUM_ION_TOKEN=
# aisstream.io key -> live AIS ship layer. NOTE: VITE_ vars are bundled into client JS;
# fine for a local/personal deploy, move behind the proxy for anything public.
VITE_AISSTREAM_KEY=
# Ollama cloud key (no VITE_ prefix — stays server-side; the vite proxy injects it
# into /feeds/llm requests). Powers AI captions + voice Q&A via minimax-m3:cloud.
OLLAMA_API_KEY=
# With none set the app still runs: 2D basemaps, no ships, template captions.
