{
  "name": "godseye",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/*.test.mjs\"",
    "electron": "electron .",
    "desktop": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.javin23863.godseye",
    "productName": "GodsEye",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "dist/**",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "cesium": "^1.126.0",
    "satellite.js": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-cesium": "^1.2.23"
  }
}
