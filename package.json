{
  "name": "godseye",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Godseye — geospatial OSINT globe (CesiumJS + live feeds, 4D playback, sensor shaders, voice + AI). Runs in the browser and as a desktop app.",
  "author": "javin23863",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/*.test.mjs\"",
    "electron": "electron .",
    "desktop": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.javin23863.godseye",
    "productName": "Godseye",
    "directories": { "output": "release" },
    "files": ["electron/**", "dist/**", "build/icon.ico", "package.json"],
    "asar": true,
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Godseye"
    },
    "portable": {
      "artifactName": "Godseye-${version}-portable.exe"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "cesium": "^1.126.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "puppeteer-core": "^25.3.0",
    "satellite.js": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-cesium": "^1.2.23"
  }
}
